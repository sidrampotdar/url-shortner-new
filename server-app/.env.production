# Production environment variables for Render deployment
# Add these values after creating MongoDB Atlas and Upstash Redis

MONGO_URI=your_mongodb_atlas_connection_string_here
REDIS_URL=your_upstash_redis_url_here
PORT=5000
NODE_ENV=production
BASE_URL=https://your-render-app-url.onrender.com
SHORT_ID_LENGTH=7
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app,https://your-custom-domain.com
